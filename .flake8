[flake8]
exclude =
    env
extend-ignore = 'E203'
max-line-length = 120
count = true
statistics = true
per-file-ignores =
    # F401: Module imported by unused (non-implicit modules)
    # TC002: Move third-party import '...' into a type-checking block
    __init__.py:F401,TC002,
    src/cds_api/routing/models.py:F821
    # ANN201: Missing return type annotation for public function
    tests/test_*:ANN201
    tests/**/test_*:ANN201
    # E501: line to long
    src/cds_api/lambda_handler.py:E501